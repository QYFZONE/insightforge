ARK_API_KEY=
ARK_MODEL_ID=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

HTTP_ADDR=:8080

# 可选值：
#   memory：内存存储，重启后数据丢失
#   sqlite：SQLite / GORM 持久化存储
STORE_DRIVER=sqlite
SQLITE_PATH=data/insightforge.db

# 可选值：
#   mock：使用假的 Agent timeline，方便本地调试主链路
#   ark：使用 Eino + 火山 Ark 真实模型
AGENT_DRIVER=mock
